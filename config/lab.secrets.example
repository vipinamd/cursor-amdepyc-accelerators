# Copy to config/lab.secrets and edit. NEVER commit the real file.
# KEY=value, '#' comments. Shared by all scripts via _lab_common.load_config().

# Linux SSH login on the DUT (and optional load-generator host)
SSH_USER=amd
SSH_PASS=amd123
# Per-host overrides (optional; fall back to SSH_PASS)
DUT_SSH_PASS=
PKTGEN_SSH_PASS=

# BMC credentials for node-level power reads (IPMI DCMI / Redfish)
BMC_USER=root
BMC_PASS=0penBmc
